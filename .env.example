# OAuth2.1 is now the default authentication method
# No environment variables are required
# Access tokens are securely stored in your system keychain

# Optional: Set logging level for debugging
# RUST_LOG=debug

# Optional: Set custom API endpoints (advanced users only)
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com

# Optional: Use staging environment (openapi.longbridge.xyz)
# LONGBRIDGE_ENV=staging
